# Copy this file to .env and fill in the values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/inventory-app

# JWT secret key (use a long, random string in production)
JWT_SECRET=your_jwt_secret_here

# JWT expiry (optional, defaults to 7d)
JWT_EXPIRES_IN=7d

# Server port (optional, defaults to 3000)
PORT=3000

# Cloudinary image storage (https://cloudinary.com — free tier available)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
