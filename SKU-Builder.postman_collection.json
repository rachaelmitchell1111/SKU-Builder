{
  "info": {
    "name": "SKU Builder – Inventory API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Items",
      "item": [
        {
          "name": "Get All Items",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/items"
          }
        },
        {
          "name": "Get Item by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/items/:id",
            "variable": [{ "key": "id", "value": "<item_id>" }]
          }
        },
        {
          "name": "Create Item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/items",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Blue T-Shirt\",\n  \"category\": \"Shirts\",\n  \"color\": \"Blue\",\n  \"price\": 29.99,\n  \"stockAmount\": 100\n}"
            }
          }
        },
        {
          "name": "Update Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/items/:id",
            "variable": [{ "key": "id", "value": "<item_id>" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 34.99,\n  \"stockAmount\": 80\n}"
            }
          }
        },
        {
          "name": "Upload Item Images",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/items/:id/images",
            "variable": [{ "key": "id", "value": "<item_id>" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "main",      "type": "file", "src": "" },
                { "key": "top",       "type": "file", "src": "" },
                { "key": "bottom",    "type": "file", "src": "" },
                { "key": "left",      "type": "file", "src": "" },
                { "key": "right",     "type": "file", "src": "" },
                { "key": "brandSize", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Delete Item",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/items/:id",
            "variable": [{ "key": "id", "value": "<item_id>" }]
          }
        }
      ]
    }
  ]
}
